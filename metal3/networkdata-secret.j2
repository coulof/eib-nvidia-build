---
# Delivers static network config to:
#   - The IPA provisioning ramdisk (preprovisioningNetworkDataName) — no DHCP needed during provisioning
#   - The deployed OS on first boot (spec.networkData) — via /mnt/openstack/latest/network_data.json
# Both fields can reference the same Secret; nmstate format is used per SUSE Edge Metal3 docs.
# Ref: https://documentation.suse.com/suse-edge/3.5/html/edge/quickstart-metal3.html#id-configuring-static-ips
apiVersion: v1
kind: Secret
metadata:
  name: {{ inventory_hostname }}-networkdata
  namespace: {{ metal3_namespace }}
type: Opaque
stringData:
  networkData: |
    interfaces:
    - name: {{ node_interface }}
      type: ethernet
      state: up
      mac-address: "{{ node_mac }}"
      ipv4:
        address:
        - ip: {{ node_ip }}
          prefix-length: {{ node_prefix }}
        enabled: true
        dhcp: false
    routes:
      config:
      - destination: 0.0.0.0/0
        next-hop-address: {{ node_gateway }}
        next-hop-interface: {{ node_interface }}
    dns-resolver:
      config:
        server:
        - {{ node_dns }}
